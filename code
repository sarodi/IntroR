# por ejemplo este paquete que nos permite explorar datos y generar gráficos por medio de una interfaz
install.packages("esquisse")
library(esquisse)
# en ocasiones, ante un error de instalación, debemos especificar desde dónde se instalan los paquetes
install.packages("tidyverse", repos = "https://cran.rstudio.com/")
# ya que instalé el paquete {datos}, debo añadirlo o cargarlo a la sesión de trabajo
# cargar librería {datos}
library(datos)
# cargar librería {datasets} (datos pre-cargados en el sistema, son internos)
library(datasets)
# explorar {datos}
data(package = "datos")
# conocer el contenido del paquete
library(help = "datasets")
??datasets
# podemos ver las primeras 6 observaciones en nuestros datos
head(encuesta)
# con este comando conocemos las variables en nuestros datos
colnames(encuesta)
# así sabemos tanto el numero de observaciones como de variables
dim(encuesta)
str(encuesta)
# estadísticos de los datos
library(skimr)
skim(encuesta)
# gráfico sencillo de una variable
encuesta %>%
  group_by(estado_civil) %>%
  summarise(n = n()) %>%
  ggplot(aes(x = estado_civil, y = n)) +
  geom_col() +
  labs(title = "Conteo de estado_civil")
